---
// Importing button component and image processor
import Button from "./Button.astro"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

interface Props {
    imagePath: string
    name: string
    industry: string
    about: string
    website: string
    tier: string
}

// Destructuring interface props
const { imagePath, name, industry, about, website, tier } = Astro.props
const isPlatinum = tier.toLowerCase() === "platinum"
const cardWidthClass = isPlatinum ? "w-full max-w-4xl" : "w-full max-w-2xl"
const imageFrameClass = isPlatinum ? "h-64 p-8" : "h-44 p-5"

// Importing images from headshots asset folder
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/sponsors/*.{jpeg,jpg,png}")
if ( !images[imagePath] ) throw new Error(` "${imagePath}" does not exist in glob: "/src/assets/sponsors/*.{jpeg,jpg,png}" `)
---

<!-- Sponsor Card -->
<div class={`h-full grid grid-rows-[auto_auto_auto_1fr_auto] gap-y-3 items-center text-center border border-zinc-700 rounded-xl p-6 bg-zinc-900/40 ${cardWidthClass}`}>
    <div class={`w-full rounded-lg border border-zinc-700 bg-black/30 flex items-center justify-center ${imageFrameClass}`}>
        <Image
            src={ images[imagePath]() }
            alt={ name }
            class="h-full w-auto object-contain"
        />
    </div>
    <span class={`font-semibold uppercase ${isPlatinum ? "text-3xl" : "text-2xl"}`}><span class="text-primary">{ tier }</span> | { name }</span>
    <span class="text-sm uppercase tracking-wider text-zinc-400">{ industry }</span>
    <span class={`pb-2 text-zinc-200 ${isPlatinum ? "text-lg" : "text-base"}`}>{ about }</span>
    <Button 
        text="Learn More" 
        type="link" 
        path={ website }
        isBordered={ true } 
        isAnimated={ true }
        isRounded={ true }
        classes="justify-self-center w-fit"
        icon ={ {
            name: "tabler:chevron-right",
            side: "right"
        }}  
    />
</div>